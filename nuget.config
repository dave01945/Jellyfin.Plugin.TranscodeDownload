<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Standard NuGet gallery -->
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!--
      Jellyfin publishes pre-release and release packages here.
      Authentication: create a GitHub PAT (read:packages scope) and run:
        dotnet nuget add source https://nuget.pkg.github.com/jellyfin/index.json
          -name jellyfin -username YOUR_GH_USER -password YOUR_PAT -store-password-in-clear-text
      Or add credentials via environment variables in CI.
    -->
    <add key="jellyfin" value="https://nuget.pkg.github.com/jellyfin/index.json" />
  </packageSources>
</configuration>
